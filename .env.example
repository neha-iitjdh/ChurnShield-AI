# ChurnShield AI Environment Configuration
# Copy this file to .env and update the values

# Application
APP_NAME="ChurnShield AI"
DEBUG=false

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Security - CHANGE THIS IN PRODUCTION!
SECRET_KEY=your-super-secret-key-change-in-production-use-openssl-rand-hex-32

# Database
DATABASE_URL=sqlite+aiosqlite:///./churnshield.db

# Streamlit
STREAMLIT_PORT=8501

# Production API URL (for frontend to connect to backend)
# Set this in the frontend service to point to your deployed API
API_BASE_URL=http://localhost:8000
